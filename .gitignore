# ==========================================
# Fullstack Food Delivery App - .gitignore
# ==========================================

# MacOS/Windows System Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Python / FastAPI
__pycache__/
*.py[cod]
*$py.class
venv/
.venv/
env/
.env
.pytest_cache/
.coverage
htmlcov/

# Node.js / Next.js
node_modules/
.next/
build/
out/
.env.local
.env.development.local
.env.test.local
.env.production.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache

# Databases
# Ignore typical SQLite/Local DB temp files but EXPLICITLY KEEP food_delivery.db for demo
*.db-journal
*.db-shm
*.db-wal
!food_delivery.db
!**/food_delivery.db
